# API Keys para los agentes AI (opcional - pone tus propias keys)

# Anthropic - Claude Code
ANTHROPIC_API_KEY=your-api-key-here

# OpenAI - Codex CLI
OPENAI_API_KEY=your-api-key-here

# Google - Gemini CLI
GEMINI_API_KEY=your-api-key-here
GOOGLE_API_KEY=your-api-key-here

# Ruta del proyecto en el host (necesaria para Docker-in-Docker)
# En Windows: HOST_PROJECT_DIR=C:/Users/tu-usuario/ruta/al/proyecto
# En Linux/Mac: HOST_PROJECT_DIR=/home/tu-usuario/ruta/al/proyecto
HOST_PROJECT_DIR=.

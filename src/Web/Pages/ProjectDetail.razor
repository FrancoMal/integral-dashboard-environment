@page "/proyecto/{ProjectId:int}"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject ToastService Toast
@inject NavigationManager Navigation

@if (loading)
{
    <div class="card">
        <div class="card-body" style="text-align:center; padding:3rem;">
            <p class="text-muted">Cargando proyecto...</p>
        </div>
    </div>
}
else if (detail == null)
{
    <div class="template-message">
        <div class="template-message-icon">@SvgIcons.AlertCircle</div>
        <h3>Proyecto no encontrado</h3>
        <p>No se pudo cargar el detalle de este proyecto.</p>
        <button class="login-btn" style="max-width:250px; margin:0 auto;" @onclick="@(() => Navigation.NavigateTo("/proyectos"))">
            Volver a Proyectos
        </button>
    </div>
}
else
{
    <div class="detail-header">
        <div class="detail-header-top">
            <button class="detail-back-btn" @onclick="@(() => Navigation.NavigateTo("/proyectos"))" title="Volver">
                @SvgIcons.Back
            </button>
            <div class="detail-title-area">
                <h2>@detail.Project.Name</h2>
                <span class="detail-fullname">@detail.Project.FullName</span>
            </div>
            <div class="detail-header-actions">
                @if (detail.Project.IsPrivate)
                {
                    <span class="repo-badge repo-badge--private">Privado</span>
                }
                @if (!string.IsNullOrEmpty(detail.Project.Language))
                {
                    <span class="repo-meta-item">
                        <span class="lang-dot" style="background:@GetLanguageColor(detail.Project.Language)"></span>
                        @detail.Project.Language
                    </span>
                }
                <button class="repo-btn repo-btn--analyze" @onclick="AnalyzeProject" disabled="@(analyzing || analyzingFeatures)">
                    @(analyzing ? "Analizando..." : "Analizar proyecto")
                </button>
                <button class="repo-btn repo-btn--features" @onclick="AnalyzeFeatures" disabled="@(analyzingFeatures || analyzing)">
                    @(analyzingFeatures ? "Pensando features..." : "Analizar features")
                </button>
                <a href="@detail.Project.HtmlUrl" target="_blank" rel="noopener" class="repo-btn repo-btn--go">
                    Abrir en GitHub
                </a>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(detail.Project.Description))
        {
            <p class="detail-description">@detail.Project.Description</p>
        }
    </div>

    @if (detail.Repo != null)
    {
        <div class="detail-stats">
            <div class="detail-stat-item">
                <span class="detail-stat-value">@detail.Repo.DefaultBranch</span>
                <span class="detail-stat-label">Branch principal</span>
            </div>
            <div class="detail-stat-item">
                <span class="detail-stat-value">@detail.Repo.StargazersCount</span>
                <span class="detail-stat-label">Estrellas</span>
            </div>
            <div class="detail-stat-item">
                <span class="detail-stat-value">@detail.Repo.ForksCount</span>
                <span class="detail-stat-label">Forks</span>
            </div>
            <div class="detail-stat-item">
                <span class="detail-stat-value">@detail.Repo.OpenIssuesCount</span>
                <span class="detail-stat-label">Issues abiertas</span>
            </div>
            <div class="detail-stat-item">
                <span class="detail-stat-value">@FormatDate(detail.Repo.PushedAt)</span>
                <span class="detail-stat-label">Ultimo push</span>
            </div>
        </div>
    }

    <div class="detail-tabs">
        <button class="detail-tab @(activeTab == "resumen" ? "active" : "")" @onclick="@(() => activeTab = "resumen")">Resumen</button>
        <button class="detail-tab @(activeTab == "actividades" ? "active" : "")" @onclick="@(() => activeTab = "actividades")">Actividades</button>
        <button class="detail-tab @(activeTab == "recomendaciones" ? "active" : "")" @onclick="@(() => activeTab = "recomendaciones")">
            Recomendaciones
            @if ((detail.Recommendations.Count + detail.Features.Count) > 0)
            {
                <span class="tab-badge">@(detail.Recommendations.Count + detail.Features.Count)</span>
            }
        </button>
        <button class="detail-tab @(activeTab == "trabajo" ? "active" : "")" @onclick="@(() => activeTab = "trabajo")">Trabajo</button>
        <button class="detail-tab @(activeTab == "historial" ? "active" : "")" @onclick="@(() => activeTab = "historial")">
            Historial
            @if (detail.Analyses.Count > 0)
            {
                <span class="tab-badge">@detail.Analyses.Count</span>
            }
        </button>
    </div>

    <div class="detail-tab-content">
        @if (activeTab == "resumen")
        {
            <div class="detail-section">
                <div class="card">
                    <div class="card-header"><h3>Informacion del repositorio</h3></div>
                    <div class="card-body">
                        <table class="info-table">
                            <tr><td class="info-label">Repositorio</td><td class="info-value">@detail.Project.FullName</td></tr>
                            <tr><td class="info-label">Branch principal</td><td class="info-value">@(detail.Repo?.DefaultBranch ?? "N/A")</td></tr>
                            <tr>
                                <td class="info-label">Lenguaje</td>
                                <td class="info-value">
                                    @if (!string.IsNullOrEmpty(detail.Project.Language))
                                    {
                                        <span class="lang-dot" style="background:@GetLanguageColor(detail.Project.Language); margin-right:0.35rem"></span>@detail.Project.Language
                                    }
                                    else
                                    {
                                        <span>N/A</span>
                                    }
                                </td>
                            </tr>
                            <tr><td class="info-label">Ultimo push</td><td class="info-value">@(detail.Repo != null ? detail.Repo.PushedAt.ToString("dd MMM yyyy HH:mm") : "N/A")</td></tr>
                            <tr><td class="info-label">Creado</td><td class="info-value">@(detail.Repo != null ? detail.Repo.CreatedAt.ToString("dd MMM yyyy") : "N/A")</td></tr>
                            <tr><td class="info-label">Importado al dashboard</td><td class="info-value">@detail.Project.ImportedAt.ToString("dd MMM yyyy")</td></tr>
                            <tr><td class="info-label">Link al repo</td><td class="info-value"><a href="@detail.Project.HtmlUrl" target="_blank" rel="noopener" class="detail-link">@detail.Project.HtmlUrl</a></td></tr>
                        </table>
                    </div>
                </div>
            </div>

            @if (detail.Analyses.Count > 0)
            {
                var lastAnalysis = detail.Analyses[0];
                <div class="detail-section">
                    <div class="card">
                        <div class="card-header"><h3>Ultimo analisis</h3></div>
                        <div class="card-body">
                            <div class="analysis-summary-card">
                                <div class="analysis-summary-meta">
                                    <span class="analysis-date">@FormatDate(lastAnalysis.AnalyzedAt)</span>
                                    <span class="analysis-files">@lastAnalysis.FilesAnalyzed archivos analizados</span>
                                    <span class="analysis-recs">@lastAnalysis.RecommendationsGenerated nuevas recomendaciones</span>
                                </div>
                                @if (!string.IsNullOrEmpty(lastAnalysis.DetectedStack))
                                {
                                    <div class="analysis-detail-row">
                                        <span class="analysis-label">Stack:</span>
                                        <div class="analysis-tags-row">
                                            @foreach (var s in lastAnalysis.DetectedStack.Split(", ", StringSplitOptions.RemoveEmptyEntries))
                                            {
                                                <span class="analysis-tag">@s</span>
                                            }
                                        </div>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(lastAnalysis.DetectedTools))
                                {
                                    <div class="analysis-detail-row">
                                        <span class="analysis-label">Herramientas:</span>
                                        <div class="analysis-tags-row">
                                            @foreach (var t in lastAnalysis.DetectedTools.Split(", ", StringSplitOptions.RemoveEmptyEntries))
                                            {
                                                <span class="analysis-tag analysis-tag--tool">@t</span>
                                            }
                                        </div>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(lastAnalysis.Summary))
                                {
                                    <p class="analysis-summary-text">@lastAnalysis.Summary</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (detail.Commits.Count > 0)
            {
                var lastCommit = detail.Commits[0];
                <div class="detail-section">
                    <div class="card">
                        <div class="card-header"><h3>Ultimo commit</h3></div>
                        <div class="card-body">
                            <div class="commit-highlight">
                                <div class="commit-highlight-msg">@GetCommitTitle(lastCommit.Message)</div>
                                <div class="commit-highlight-meta">
                                    <span>@lastCommit.AuthorName</span>
                                    <span class="commit-sha">@lastCommit.Sha[..7]</span>
                                    <span>@FormatDate(lastCommit.Date)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(detail.Readme))
            {
                <div class="detail-section">
                    <div class="card">
                        <div class="card-header"><h3>README.md</h3></div>
                        <div class="card-body readme-content">
                            <pre class="readme-pre">@detail.Readme</pre>
                        </div>
                    </div>
                </div>
            }
        }
        else if (activeTab == "actividades")
        {
            <div class="detail-section">
                <div class="card">
                    <div class="card-header"><h3>Commits recientes</h3></div>
                    <div class="card-body" style="padding:0;">
                        @if (detail.Commits.Count == 0)
                        {
                            <div style="padding:2rem; text-align:center;"><p class="text-muted">No se encontraron commits.</p></div>
                        }
                        else
                        {
                            <div class="commits-list">
                                @foreach (var commit in detail.Commits)
                                {
                                    <div class="commit-item">
                                        <div class="commit-item-left">
                                            @if (!string.IsNullOrEmpty(commit.AuthorAvatar))
                                            {
                                                <img src="@commit.AuthorAvatar" alt="" class="commit-avatar" />
                                            }
                                            else
                                            {
                                                <div class="commit-avatar-placeholder">@SvgIcons.User</div>
                                            }
                                            <div class="commit-item-info">
                                                <div class="commit-msg">@GetCommitTitle(commit.Message)</div>
                                                <div class="commit-meta"><span class="commit-author">@(commit.AuthorLogin ?? commit.AuthorName)</span> committed @FormatDate(commit.Date)</div>
                                            </div>
                                        </div>
                                        <a href="@commit.HtmlUrl" target="_blank" rel="noopener" class="commit-sha-link" title="Ver en GitHub">@commit.Sha[..7]</a>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else if (activeTab == "recomendaciones")
        {
            <div class="detail-section">
                <div class="card">
                    <div class="card-header work-card-header collapsible-header" @onclick="@(() => recsCollapsed = !recsCollapsed)">
                        <div style="display:flex; align-items:center; gap:0.5rem;">
                            <span class="collapse-arrow @(recsCollapsed ? "" : "open")">&#9654;</span>
                            <div>
                                <h3>Recomendaciones del analisis <span class="collapse-count">(@detail.Recommendations.Count)</span></h3>
                            </div>
                        </div>
                        @if (!recsCollapsed)
                        {
                            <button class="repo-btn repo-btn--import" @onclick="MoveSelectedToBacklog" @onclick:stopPropagation="true" disabled="@(movingToBacklog || SelectedCount == 0)">
                                @(movingToBacklog ? "Moviendo..." : $"Pasar al backlog ({SelectedCount})")
                            </button>
                        }
                    </div>
                    <div class="card-body @(recsCollapsed ? "collapsed-body" : "")">
                        @if (recsCollapsed)
                        {
                            <p class="collapsed-summary">@detail.Recommendations.Count recomendaciones · @detail.Recommendations.Count(r => r.AddedToBacklog) en backlog</p>
                        }
                        else if (detail.Recommendations.Count == 0)
                        {
                            <div class="work-empty-state">
                                <div class="template-message-icon">@SvgIcons.Check</div>
                                <p>Todavia no hay recomendaciones. Usa <strong>Analizar proyecto</strong> para generarlas.</p>
                            </div>
                        }
                        else
                        {
                            <div class="rec-filters">
                                <button class="rec-filter-btn @(categoryFilter == null ? "active" : "")"
                                        @onclick="@(() => categoryFilter = null)">
                                    Todas (@detail.Recommendations.Count)
                                </button>
                                @foreach (var cat in AllCategories)
                                {
                                    var count = detail.Recommendations.Count(r => r.Category == cat);
                                    <button class="rec-filter-btn rec-filter-btn--@cat @(categoryFilter == cat ? "active" : "")"
                                            @onclick="@(() => categoryFilter = cat)">
                                        @cat (@count)
                                    </button>
                                }
                            </div>

                            <div class="recommendations-list">
                                @foreach (var recommendation in FilteredRecommendations)
                                {
                                    <div class="recommendation-card @(recommendation.AddedToBacklog ? "is-added" : "")">
                                        <input type="checkbox"
                                               checked="@recommendation.Selected"
                                               disabled="@recommendation.AddedToBacklog"
                                               @onchange="@(async e => await ToggleRecommendation(recommendation, e.Value as bool? == true))" />
                                        <div class="recommendation-body">
                                            <div class="recommendation-top">
                                                <div>
                                                    <div class="recommendation-title">@recommendation.Title</div>
                                                    <div class="recommendation-notes">@recommendation.Notes</div>
                                                </div>
                                                <div class="recommendation-tags">
                                                    <span class="recommendation-tag rec-cat--@recommendation.Category">@recommendation.Category</span>
                                                    <span class="recommendation-tag recommendation-tag--priority recommendation-tag--p@recommendation.Priority">P@recommendation.Priority</span>
                                                    @if (recommendation.AddedToBacklog)
                                                    {
                                                        <span class="recommendation-tag recommendation-tag--done">En backlog</span>
                                                    }
                                                </div>
                                            </div>
                                            <div class="recommendation-user-notes">
                                                @if (editingNoteId == recommendation.Id)
                                                {
                                                    <div class="note-edit-area">
                                                        <textarea class="note-textarea" rows="2"
                                                                  @bind="editingNoteText" placeholder="Escribi tu nota..."></textarea>
                                                        <div class="note-edit-actions">
                                                            <button class="note-btn note-btn--save" @onclick="@(() => SaveNote(recommendation))">Guardar</button>
                                                            <button class="note-btn note-btn--cancel" @onclick="@(() => editingNoteId = 0)">Cancelar</button>
                                                        </div>
                                                    </div>
                                                }
                                                else if (!string.IsNullOrEmpty(recommendation.UserNotes))
                                                {
                                                    <div class="note-display" @onclick="@(() => StartEditNote(recommendation))">
                                                        <span class="note-label">Tu nota:</span> @recommendation.UserNotes
                                                    </div>
                                                }
                                                else
                                                {
                                                    <button class="note-add-btn" @onclick="@(() => StartEditNote(recommendation))">+ Agregar nota</button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* ---- Ideas de Features (dentro de Recomendaciones) ---- *@
            <div class="detail-section">
                <div class="card">
                    <div class="card-header work-card-header collapsible-header" @onclick="@(() => featuresCollapsed = !featuresCollapsed)">
                        <div style="display:flex; align-items:center; gap:0.5rem;">
                            <span class="collapse-arrow @(featuresCollapsed ? "" : "open")">&#9654;</span>
                            <div>
                                <h3>Ideas de Features <span class="collapse-count">(@detail.Features.Count)</span></h3>
                            </div>
                        </div>
                        <div style="display:flex; gap:0.5rem; align-items:center;" @onclick:stopPropagation="true">
                            <button class="repo-btn repo-btn--analyze" style="font-size:0.8rem; padding:0.4rem 0.85rem;" @onclick="@(() => showCustomFeatureForm = !showCustomFeatureForm)">
                                @(showCustomFeatureForm ? "Cancelar" : "Agregar feature")
                            </button>
                            @if (!featuresCollapsed && detail.Features.Any(f => selectedFeatureIds.Contains(f.Id) && !f.AddedToBacklog))
                            {
                                <button class="repo-btn repo-btn--import" @onclick="MoveFeaturesToBacklog" disabled="@movingToBacklog">
                                    @(movingToBacklog ? "Moviendo..." : $"Pasar al backlog ({selectedFeatureIds.Count(id => detail.Features.Any(f => f.Id == id && !f.AddedToBacklog))})")
                                </button>
                            }
                        </div>
                    </div>
                    <div class="card-body @(featuresCollapsed && !showCustomFeatureForm ? "collapsed-body" : "")">
                        @if (featuresCollapsed && !showCustomFeatureForm)
                        {
                            <p class="collapsed-summary">@detail.Features.Count features · @detail.Features.Count(f => f.AddedToBacklog) en backlog</p>
                        }
                        else if (showCustomFeatureForm)
                        {
                            <div class="custom-feature-form">
                                <div class="custom-feature-field">
                                    <label>Titulo</label>
                                    <input type="text" class="note-textarea" style="padding:0.5rem 0.65rem; min-height:auto;" @bind="customFeatureTitle" placeholder="Nombre de la feature..." />
                                </div>
                                <div class="custom-feature-field">
                                    <label>Descripcion</label>
                                    <textarea class="note-textarea" rows="2" @bind="customFeatureDescription" placeholder="Que hace esta feature..."></textarea>
                                </div>
                                <div class="custom-feature-field">
                                    <label>Plan de implementacion (opcional)</label>
                                    <textarea class="note-textarea" rows="3" @bind="customFeatureImplementation" placeholder="Pasos para implementarla..."></textarea>
                                </div>
                                <div class="note-edit-actions">
                                    <button class="note-btn note-btn--save" @onclick="SaveCustomFeature" disabled="@(savingCustomFeature || string.IsNullOrWhiteSpace(customFeatureTitle))">
                                        @(savingCustomFeature ? "Guardando..." : "Guardar feature")
                                    </button>
                                    <button class="note-btn note-btn--cancel" @onclick="@(() => { showCustomFeatureForm = false; customFeatureTitle = ""; customFeatureDescription = ""; customFeatureImplementation = ""; })">Cancelar</button>
                                </div>
                            </div>
                        }

                        @if (detail.Features.Count == 0 && !showCustomFeatureForm)
                        {
                            <div class="work-empty-state">
                                <div class="template-message-icon">@SvgIcons.Code</div>
                                <p>Todavia no hay features propuestas. Usa <strong>Analizar features</strong> para que la IA genere ideas, o <strong>Agregar feature</strong> para crear una propia.</p>
                            </div>
                        }
                        else if (detail.Features.Count > 0)
                        {
                            <div class="features-list">
                                @foreach (var feature in detail.Features)
                                {
                                    <div class="feature-card @(feature.AddedToBacklog ? "is-added" : "") @(expandedFeatureId == feature.Id ? "is-expanded" : "")">
                                        <div class="feature-card-header">
                                            <input type="checkbox"
                                                   checked="@selectedFeatureIds.Contains(feature.Id)"
                                                   disabled="@feature.AddedToBacklog"
                                                   @onchange="@(e => ToggleFeatureSelection(feature.Id, e.Value as bool? == true))" />
                                            <div class="feature-card-title-area" @onclick="@(() => ToggleFeatureExpand(feature.Id))">
                                                <div class="feature-title">@feature.Title</div>
                                                <div class="feature-description">@feature.Description</div>
                                            </div>
                                            <div class="feature-tags">
                                                <span class="recommendation-tag rec-cat--@(feature.Complexity == "alta" ? "seguridad" : feature.Complexity == "media" ? "planning" : "documentacion")">@feature.Complexity</span>
                                                @if (feature.AddedToBacklog)
                                                {
                                                    <span class="recommendation-tag recommendation-tag--done">En backlog</span>
                                                }
                                            </div>
                                        </div>
                                        @if (expandedFeatureId == feature.Id)
                                        {
                                            <div class="feature-card-detail">
                                                <div class="feature-section">
                                                    <div class="feature-section-title">Plan de implementacion</div>
                                                    <pre class="feature-implementation">@feature.Implementation</pre>
                                                </div>
                                                @if (!string.IsNullOrEmpty(feature.FilesToModify))
                                                {
                                                    <div class="feature-section">
                                                        <div class="feature-section-title">Archivos a modificar</div>
                                                        <div class="feature-files">
                                                            @foreach (var file in feature.FilesToModify.Split(",", StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                                            {
                                                                <span class="feature-file-tag">@file</span>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        <div class="recommendation-user-notes" style="padding: 0 1rem 0.75rem;">
                                            @if (editingFeatureNoteId == feature.Id)
                                            {
                                                <div class="note-edit-area">
                                                    <textarea class="note-textarea" rows="2"
                                                              @bind="editingNoteText" placeholder="Escribi tu nota..."></textarea>
                                                    <div class="note-edit-actions">
                                                        <button class="note-btn note-btn--save" @onclick="@(() => SaveFeatureNote(feature))">Guardar</button>
                                                        <button class="note-btn note-btn--cancel" @onclick="@(() => editingFeatureNoteId = 0)">Cancelar</button>
                                                    </div>
                                                </div>
                                            }
                                            else if (!string.IsNullOrEmpty(feature.UserNotes))
                                            {
                                                <div class="note-display" @onclick="@(() => { editingFeatureNoteId = feature.Id; editingNoteText = feature.UserNotes ?? ""; })">
                                                    <span class="note-label">Tu nota:</span> @feature.UserNotes
                                                </div>
                                            }
                                            else
                                            {
                                                <button class="note-add-btn" @onclick="@(() => { editingFeatureNoteId = feature.Id; editingNoteText = ""; })">+ Agregar nota</button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else if (activeTab == "trabajo")
        {
            @if (orchStatus != null && orchStatus.IsAlive)
            {
                <div class="detail-section">
                    <div class="card orch-card orch-card--@orchStatus.Status">
                        <div class="card-header work-card-header">
                            <div>
                                <h3>
                                    <span class="orch-dot orch-dot--@orchStatus.Status"></span>
                                    Orquestador
                                    <span class="orch-status-label">@GetOrchStatusLabel(orchStatus.Status)</span>
                                </h3>
                                @if (!string.IsNullOrEmpty(orchStatus.Provider))
                                {
                                    <p class="work-card-subtitle">Proveedor: @orchStatus.Provider</p>
                                }
                            </div>
                            @if (orchStatus.Status == "working" && !string.IsNullOrEmpty(orchStatus.CurrentTask))
                            {
                                <span class="recommendation-tag rec-cat--arquitectura">@orchStatus.CurrentProjectName</span>
                            }
                        </div>
                        @if (orchStatus.Status == "working")
                        {
                            <div class="card-body">
                                <div class="orch-task">Tarea: <strong>@orchStatus.CurrentTask</strong></div>
                                @if (!string.IsNullOrEmpty(orchStatus.Output))
                                {
                                    <div class="orch-output-area">
                                        <div class="feature-section-title">Sesion en vivo</div>
                                        <pre class="orch-output">@orchStatus.Output</pre>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="detail-section">
                <div class="card">
                    <div class="card-header"><h3>Trabajo del proyecto</h3></div>
                    <div class="card-body">
                        <div class="work-columns">
                            @foreach (var status in statuses)
                            {
                                var items = detail.WorkItems.Where(w => w.Status == status.Key).ToList();
                                <div class="work-column">
                                    <div class="work-column-header @status.HeaderClass">
                                        <span class="work-column-dot" style="background:@status.Color"></span>
                                        @status.Label
                                    </div>
                                    <div class="work-column-body">
                                        @if (items.Count == 0)
                                        {
                                            <div class="work-empty">Sin items todavia</div>
                                        }
                                        else
                                        {
                                            <div class="work-items-list">
                                                @foreach (var item in items)
                                                {
                                                    <div class="work-item-card">
                                                        <div class="work-item-title">@item.Title</div>
                                                        <div class="work-item-notes">@item.Notes</div>
                                                        <div class="work-item-meta">
                                                            <span>@item.Source · @FormatDate(item.CreatedAt)</span>
                                                            @if (status.Key == "in_progress")
                                                            {
                                                                <button class="work-item-remove-btn" @onclick="@(() => MoveWorkItemToBacklog(item))" title="Mover a backlog">Quitar</button>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (activeTab == "historial")
        {
            <div class="detail-section">
                <div class="card">
                    <div class="card-header"><h3>Historial de analisis</h3></div>
                    <div class="card-body">
                        @if (detail.Analyses.Count == 0)
                        {
                            <div class="work-empty-state">
                                <div class="template-message-icon">@SvgIcons.AlertCircle</div>
                                <p>Todavia no se analizo este proyecto. Usa <strong>Analizar proyecto</strong> para generar el primer analisis.</p>
                            </div>
                        }
                        else
                        {
                            <div class="analysis-timeline">
                                @{ var analysesList = detail.Analyses.ToList(); }
                                @for (int i = 0; i < analysesList.Count; i++)
                                {
                                    var analysis = analysesList[i];
                                    var recsForThis = detail.Recommendations.Where(r => r.AnalysisId == analysis.Id).ToList();
                                    var previousAnalysis = i + 1 < analysesList.Count ? analysesList[i + 1] : null;

                                    <div class="analysis-timeline-item">
                                        <div class="analysis-timeline-dot"></div>
                                        <div class="analysis-timeline-content">
                                            <div class="analysis-timeline-header">
                                                <span class="analysis-timeline-date">@analysis.AnalyzedAt.ToString("dd MMM yyyy HH:mm")</span>
                                                <span class="analysis-timeline-badge">@analysis.FilesAnalyzed archivos</span>
                                                <span class="analysis-timeline-badge analysis-timeline-badge--recs">+@analysis.RecommendationsGenerated recomendaciones</span>
                                            </div>
                                            @if (!string.IsNullOrEmpty(analysis.DetectedStack))
                                            {
                                                <div class="analysis-detail-row">
                                                    <span class="analysis-label">Stack:</span>
                                                    <div class="analysis-tags-row">
                                                        @foreach (var s in analysis.DetectedStack.Split(", ", StringSplitOptions.RemoveEmptyEntries))
                                                        {
                                                            <span class="analysis-tag">@s</span>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(analysis.DetectedTools))
                                            {
                                                <div class="analysis-detail-row">
                                                    <span class="analysis-label">Herramientas:</span>
                                                    <div class="analysis-tags-row">
                                                        @foreach (var t in analysis.DetectedTools.Split(", ", StringSplitOptions.RemoveEmptyEntries))
                                                        {
                                                            <span class="analysis-tag analysis-tag--tool">@t</span>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(analysis.Summary))
                                            {
                                                <p class="analysis-summary-text">@analysis.Summary</p>
                                            }

                                            @* Diff vs previous analysis *@
                                            @if (previousAnalysis != null)
                                            {
                                                var prevStack = (previousAnalysis.DetectedStack ?? "").Split(", ", StringSplitOptions.RemoveEmptyEntries).ToHashSet();
                                                var currStack = (analysis.DetectedStack ?? "").Split(", ", StringSplitOptions.RemoveEmptyEntries).ToHashSet();
                                                var newStackItems = currStack.Except(prevStack).ToList();
                                                var removedStackItems = prevStack.Except(currStack).ToList();
                                                var diffRecs = analysis.RecommendationsGenerated - previousAnalysis.RecommendationsGenerated;

                                                @if (newStackItems.Any() || removedStackItems.Any() || diffRecs != 0)
                                                {
                                                    <div class="analysis-diff-section">
                                                        <div class="analysis-diff-title">Cambios vs analisis anterior</div>
                                                        @if (diffRecs > 0)
                                                        {
                                                            <span class="analysis-diff-item analysis-diff-item--added">+@diffRecs nuevas recomendaciones</span>
                                                        }
                                                        else if (diffRecs < 0)
                                                        {
                                                            <span class="analysis-diff-item analysis-diff-item--removed">@diffRecs recomendaciones</span>
                                                        }
                                                        @foreach (var ns in newStackItems)
                                                        {
                                                            <span class="analysis-diff-item analysis-diff-item--added">+ @ns</span>
                                                        }
                                                        @foreach (var rs in removedStackItems)
                                                        {
                                                            <span class="analysis-diff-item analysis-diff-item--removed">- @rs</span>
                                                        }
                                                    </div>
                                                }
                                            }

                                            @* Recommendations generated in this analysis *@
                                            @if (recsForThis.Count > 0)
                                            {
                                                <div class="analysis-recs-section">
                                                    <div class="analysis-recs-title">Recomendaciones generadas en este analisis</div>
                                                    <div class="analysis-recs-list">
                                                        @foreach (var rec in recsForThis.Take(5))
                                                        {
                                                            <div class="analysis-rec-item">
                                                                <span class="recommendation-tag rec-cat--@rec.Category" style="font-size:0.65rem; padding:0.1rem 0.4rem;">@rec.Category</span>
                                                                <span>@rec.Title</span>
                                                            </div>
                                                        }
                                                        @if (recsForThis.Count > 5)
                                                        {
                                                            <div class="analysis-rec-item" style="color:var(--text-muted); font-style:italic;">
                                                                ...y @(recsForThis.Count - 5) mas
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            }

                                            <div class="analysis-timeline-footer">
                                                Total acumulado: @analysis.TotalRecommendations recomendaciones
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public int ProjectId { get; set; }

    private ProjectDetailDto? detail;
    private bool loading = true;
    private bool analyzing;
    private bool analyzingFeatures;
    private bool movingToBacklog;
    private string activeTab = "resumen";
    private string? categoryFilter;
    private int editingNoteId;
    private int editingFeatureNoteId;
    private string editingNoteText = "";
    private HashSet<int> selectedFeatureIds = new();
    private int expandedFeatureId;
    private bool showCustomFeatureForm;
    private bool recsCollapsed;
    private bool featuresCollapsed;
    private string customFeatureTitle = "";
    private string customFeatureDescription = "";
    private string customFeatureImplementation = "";
    private bool savingCustomFeature;
    private OrchestratorStatusDto? orchStatus;
    private System.Threading.Timer? orchPollTimer;

    private readonly (string Key, string Label, string Color, string HeaderClass)[] statuses =
    [
        ("backlog", "Backlog", "var(--text-muted)", "work-column--backlog"),
        ("in_progress", "En progreso", "var(--info)", "work-column--progress"),
        ("done", "Completado", "var(--primary)", "work-column--done")
    ];

    private int SelectedCount => detail?.Recommendations.Count(r => r.Selected && !r.AddedToBacklog) ?? 0;

    private IEnumerable<string> AllCategories => detail?.Recommendations
        .Select(r => r.Category).Distinct().OrderBy(c => c) ?? Enumerable.Empty<string>();

    private IEnumerable<ProjectRecommendationDto> FilteredRecommendations => detail?.Recommendations
        .Where(r => categoryFilter == null || r.Category == categoryFilter)
        ?? Enumerable.Empty<ProjectRecommendationDto>();

    protected override async Task OnInitializedAsync()
    {
        await LoadDetail();
        await LoadOrchStatus();
        // Poll orchestrator status every 5 seconds
        orchPollTimer = new System.Threading.Timer(async _ =>
        {
            await LoadOrchStatus();
            await InvokeAsync(StateHasChanged);
        }, null, 5000, 5000);
    }

    public void Dispose()
    {
        orchPollTimer?.Dispose();
    }

    private async Task LoadDetail()
    {
        loading = true;
        try
        {
            detail = await Api.GetProjectDetailAsync(ProjectId);
        }
        catch
        {
            Toast.Error("Error al cargar el detalle del proyecto");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task AnalyzeProject()
    {
        analyzing = true;
        try
        {
            var result = await Api.AnalyzeProjectAsync(ProjectId);
            await LoadDetail();
            activeTab = "recomendaciones";
            if (result?.Generated > 0)
            {
                var msg = $"Analisis profundo listo: {result.Generated} recomendaciones nuevas ({result.FilesAnalyzed} archivos analizados)";
                Toast.Success(msg);
            }
            else
            {
                Toast.Success($"Analisis profundo listo: sin recomendaciones nuevas ({result?.FilesAnalyzed ?? 0} archivos analizados)");
            }
        }
        catch
        {
            Toast.Error("No se pudo analizar el proyecto");
        }
        finally
        {
            analyzing = false;
        }
    }

    private async Task ToggleRecommendation(ProjectRecommendationDto recommendation, bool selected)
    {
        recommendation.Selected = selected;
        try
        {
            await Api.UpdateRecommendationSelectionAsync(ProjectId, recommendation.Id, selected);
        }
        catch
        {
            recommendation.Selected = !selected;
            Toast.Error("No se pudo actualizar la seleccion");
        }
    }

    private async Task MoveSelectedToBacklog()
    {
        movingToBacklog = true;
        try
        {
            var moved = await Api.MoveSelectedRecommendationsToBacklogAsync(ProjectId);
            await LoadDetail();
            Toast.Success(moved > 0
                ? $"{moved} recomendacion(es) pasaron al backlog"
                : "No habia recomendaciones seleccionadas para mover");
        }
        catch
        {
            Toast.Error("No se pudieron mover las recomendaciones al backlog");
        }
        finally
        {
            movingToBacklog = false;
        }
    }

    private async Task AnalyzeFeatures()
    {
        analyzingFeatures = true;
        try
        {
            var result = await Api.AnalyzeFeaturesAsync(ProjectId);
            await LoadDetail();
            activeTab = "recomendaciones";
            Toast.Success(result?.Generated > 0
                ? $"Listo: {result.Generated} features nuevas propuestas"
                : "No se generaron features nuevas");
        }
        catch
        {
            Toast.Error("No se pudieron analizar features. Verifica que el servicio de IA este activo.");
        }
        finally
        {
            analyzingFeatures = false;
        }
    }

    private void ToggleFeatureSelection(int featureId, bool selected)
    {
        if (selected) selectedFeatureIds.Add(featureId);
        else selectedFeatureIds.Remove(featureId);
    }

    private void ToggleFeatureExpand(int featureId)
    {
        expandedFeatureId = expandedFeatureId == featureId ? 0 : featureId;
    }

    private async Task MoveFeaturesToBacklog()
    {
        movingToBacklog = true;
        try
        {
            var ids = selectedFeatureIds.ToList();
            var moved = await Api.MoveFeaturesToBacklogAsync(ProjectId, ids);
            await LoadDetail();
            selectedFeatureIds.Clear();
            Toast.Success(moved > 0 ? $"{moved} feature(s) pasaron al backlog" : "No habia features para mover");
        }
        catch
        {
            Toast.Error("No se pudieron mover las features al backlog");
        }
        finally
        {
            movingToBacklog = false;
        }
    }

    private async Task SaveFeatureNote(ProjectFeatureDto feature)
    {
        try
        {
            await Api.UpdateFeatureNotesAsync(ProjectId, feature.Id, editingNoteText);
            feature.UserNotes = editingNoteText;
            editingFeatureNoteId = 0;
        }
        catch
        {
            Toast.Error("No se pudo guardar la nota");
        }
    }

    private void StartEditNote(ProjectRecommendationDto recommendation)
    {
        editingNoteId = recommendation.Id;
        editingNoteText = recommendation.UserNotes ?? "";
    }

    private async Task SaveNote(ProjectRecommendationDto recommendation)
    {
        try
        {
            await Api.UpdateRecommendationNotesAsync(ProjectId, recommendation.Id, editingNoteText);
            recommendation.UserNotes = editingNoteText;
            editingNoteId = 0;
        }
        catch
        {
            Toast.Error("No se pudo guardar la nota");
        }
    }

    private async Task MoveWorkItemToBacklog(ProjectWorkItemDto item)
    {
        try
        {
            await Api.UpdateWorkItemStatusAsync(ProjectId, item.Id, "backlog");
            item.Status = "backlog";
            Toast.Success("Item movido al backlog");
        }
        catch
        {
            Toast.Error("No se pudo mover el item al backlog");
        }
    }

    private async Task SaveCustomFeature()
    {
        if (string.IsNullOrWhiteSpace(customFeatureTitle)) return;
        savingCustomFeature = true;
        try
        {
            await Api.CreateCustomFeatureAsync(ProjectId, customFeatureTitle.Trim(), customFeatureDescription.Trim(), customFeatureImplementation.Trim());
            await LoadDetail();
            showCustomFeatureForm = false;
            customFeatureTitle = "";
            customFeatureDescription = "";
            customFeatureImplementation = "";
            Toast.Success("Feature agregada");
        }
        catch
        {
            Toast.Error("No se pudo crear la feature");
        }
        finally
        {
            savingCustomFeature = false;
        }
    }

    private async Task LoadOrchStatus()
    {
        try { orchStatus = await Api.GetOrchestratorStatusAsync(); } catch { }
    }

    private string GetOrchStatusLabel(string status) => status switch
    {
        "working" => "Trabajando",
        "scanning" => "Buscando tareas",
        "idle" => "Esperando",
        "error" => "Error",
        _ => "Offline"
    };

    private string GetCommitTitle(string message)
    {
        var firstLine = message.Split('\n')[0];
        return firstLine.Length > 80 ? firstLine[..77] + "..." : firstLine;
    }

    private string FormatDate(DateTime date)
    {
        var diff = DateTime.UtcNow - date;
        if (diff.TotalMinutes < 60) return $"hace {(int)diff.TotalMinutes} min";
        if (diff.TotalHours < 24) return $"hace {(int)diff.TotalHours}h";
        if (diff.TotalDays < 30) return $"hace {(int)diff.TotalDays}d";
        return date.ToString("dd MMM yyyy");
    }

    private string GetLanguageColor(string lang) => lang?.ToLower() switch
    {
        "c#" => "#178600",
        "javascript" => "#f1e05a",
        "typescript" => "#3178c6",
        "python" => "#3572A5",
        "html" => "#e34c26",
        "css" => "#563d7c",
        "java" => "#b07219",
        "go" => "#00ADD8",
        "rust" => "#dea584",
        _ => "#8b949e"
    };
}
